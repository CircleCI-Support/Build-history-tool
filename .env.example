# Copy this file to `.env` and fill in your values.
# `.env` is gitignored; `.env.example` is safe to commit.

# Personal API token (User Settings → Personal API Tokens on CircleCI).
CIRCLE_TOKEN=your-circleci-personal-api-token

# Default project slug, e.g. gh/myorg/myrepo or bb/my-workspace/myrepo.
# --project / -p on the command line overrides this.
CIRCLECI_PROJECT_SLUG=gh/myorg/myrepo
